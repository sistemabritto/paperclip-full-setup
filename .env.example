DOMAIN=paperclip.workflowapi.com.br
PAPERCLIP_IMAGE=sistemabritto/paperclip-full-setup:latest

PAPERCLIP_HOME=/paperclip
PAPERCLIP_INSTANCE_ID=default
PAPERCLIP_CONFIG=/paperclip/instances/default/config.json
PAPERCLIP_DEPLOYMENT_MODE=authenticated
PAPERCLIP_DEPLOYMENT_EXPOSURE=private
PORT=3100

BETTER_AUTH_SECRET=change-me
PAPERCLIP_AGENT_JWT_SECRET=change-me
PAPERCLIP_ENCRYPTION_KEY=change-me

DATABASE_URL=postgresql://paperclip:change-me@postgres:5432/paperclip

HERMES_HOME=/paperclip/.hermes
PAPERCLIP_API_URL=https://paperclip.workflowapi.com.br/api

HERMES_MODEL=qwen/qwen3.5-122b-a10b
HERMES_BASE_URL=https://integrate.api.nvidia.com/v1
HERMES_API_KEY=change-me

IMAGE_NAME=sistemabritto/paperclip-full-setup
